{
    "name": "wotz/laravel-social-media-share",
    "description": "A Laravel package for social sharing. This package is a rewrite from jorenvanhocht/laravel-share.",
    "keywords": [
        "laravel",
        "social",
        "sharing",
        "social media links",
        "who owns the zebra"
    ],
    "homepage": "https://github.com/wotzebra/laravel-social-media-share",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.9"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Wotz\\SocialMediaShare\\": "./src"
        }
    },
    "autoload-dev": {
        "psr-4": {
          "Wotz\\SocialMediaShare\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
          "providers": [
            "Wotz\\SocialMediaShare\\SocialMediaShareServiceProvider"
          ]
        }
      },
    "config": {
      "sort-packages": true,
      "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
